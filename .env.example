# =============================================================
#  방주 프로젝트 환경변수 예시 파일
#  - 이 파일을 복사해서 ".env" 라는 이름으로 만든 뒤 값을 채우세요. (로컬 테스트용)
#  - Railway에 배포할 때는 .env 대신 Railway의 "Variables" 탭에 같은 이름으로 넣습니다.
#  - 절대로 .env 파일을 GitHub에 올리지 마세요. (.gitignore가 막아줍니다)
# =============================================================

# [필수] 관리자 페이지 로그인 비밀번호 (원하는 값으로 바꾸세요)
ADMIN_PASSWORD=원하는비밀번호

# [필수] 구글 시트 ID
#  - 시트 주소 https://docs.google.com/spreadsheets/d/여기가_ID/edit  에서 가운데 부분
SHEET_ID=여기에_구글시트_ID

# [선택] 데이터가 들어있는 탭(시트) 이름. 기본값은 Plants
SHEET_NAME=Plants

# [필수] 구글 서비스 계정 키(JSON) 전체를 "한 줄"로 붙여넣기
#  - 다운로드한 JSON 파일 내용을 통째로 작은따옴표 없이 그대로 넣습니다.
#  - 예: {"type":"service_account","project_id":"...","private_key":"-----BEGIN..."}
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ... }

# [필수] 솔라피 API 키 (솔라피 콘솔 > 개발/연동 > API Key)
SOLAPI_API_KEY=여기에_API_KEY
SOLAPI_API_SECRET=여기에_API_SECRET

# [필수] 솔라피에 등록한 발신번호 (사전 등록 필요)
SENDER_PHONE=01012345678

# [선택] 알림톡 설정 — 템플릿/발신프로필이 확정되면 채우세요.
#  둘 다 비어 있으면 자동으로 '문자(LMS)'로 발송됩니다.
KAKAO_PFID=
ALIMTALK_TEMPLATE_ID=
# 템플릿 변수명이 다르면 여기서 맞춰주세요 (기본: #{고객명}, #{링크})
ALIMTALK_VAR_NAME=#{고객명}
ALIMTALK_VAR_LINK=#{링크}

# [필수] 배포 후 사이트 기본 주소 (끝에 / 없이)
#  - Railway 배포 후 받은 도메인을 넣으세요. 예: https://ark.up.railway.app
#  - 로컬 테스트 중에는 비워두어도 됩니다.
BASE_URL=

# [선택] 세션 암호화용 임의 문자열 (아무 긴 문자열)
SESSION_SECRET=아무거나_긴_랜덤_문자열
