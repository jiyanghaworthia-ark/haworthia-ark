<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>발송 내역 · 관리자 | ARK PROJECT</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <style>
    :root { --green:#1A3620; --gold:#D4AF37; --gold-soft:#E8D9A0; --paper:#FBF8F0; --line:rgba(212,175,55,0.22); }
    * { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:'Noto Sans KR',sans-serif; background:linear-gradient(160deg,#1A3620,#0E1F12); color:var(--paper); min-height:100vh; padding:26px 14px 60px; }
    .wrap { max-width:820px; margin:0 auto; }
    .top { display:flex; justify-content:space-between; align-items:center; margin-bottom:18px; }
    .logo { font-family:'Playfair Display',serif; color:var(--gold); letter-spacing:3px; font-size:15px; }
    .nav a, .logout { color:var(--gold-soft); font-size:12px; text-decoration:none; border:1px solid rgba(212,175,55,0.4); padding:6px 12px; border-radius:6px; background:none; cursor:pointer; margin-left:6px; }
    .nav a.active { background:var(--gold); color:#10220f; border-color:var(--gold); }
    .alert { padding:12px 15px; border-radius:8px; font-size:14px; margin-bottom:16px; }
    .err { background:rgba(180,40,40,0.25); border:1px solid rgba(220,80,80,0.5); color:#ffd9d9; }
    .ok { background:rgba(40,120,60,0.25); border:1px solid rgba(120,200,140,0.5); color:#d6ffe0; }
    .panel { background:rgba(0,0,0,0.22); border:1px solid var(--line); border-radius:14px; overflow:hidden; margin-bottom:18px; }
    .ph { background:rgba(212,175,55,0.10); padding:13px 18px; border-bottom:1px solid var(--line); font-size:14px; color:#fff; }
    table { width:100%; border-collapse:collapse; font-size:13px; }
    th, td { padding:10px 12px; text-align:left; border-bottom:1px solid var(--line); }
    th { color:var(--gold-soft); font-weight:400; font-size:12px; background:rgba(255,255,255,0.02); }
    td { color:#fff; }
    .muted { color:var(--gold-soft); }
    .del { background:rgba(180,40,40,0.25); border:1px solid rgba(220,80,80,0.5); color:#ffd9d9; border-radius:6px; padding:5px 10px; font-size:12px; cursor:pointer; }
    .empty { padding:28px; text-align:center; color:var(--gold-soft); opacity:0.7; font-size:13px; }
    .addgrid { display:grid; grid-template-columns:repeat(6, 1fr); gap:8px; padding:16px 18px; }
    .addgrid input { width:100%; padding:9px 10px; border-radius:7px; border:1px solid rgba(212,175,55,0.3); background:rgba(255,255,255,0.06); color:#fff; font-size:13px; font-family:inherit; }
    .addgrid input:focus { outline:none; border-color:var(--gold); }
    .addbar { padding:0 18px 16px; }
    .addbar button { padding:11px 20px; border:none; border-radius:8px; background:linear-gradient(180deg,#E6C75A,#D4AF37); color:#10220f; font-weight:700; cursor:pointer; font-size:14px; }
    .hint { font-size:11px; color:var(--gold-soft); opacity:0.6; padding:0 18px 8px; }
    @media (max-width:640px){ .addgrid { grid-template-columns:repeat(2,1fr); } }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="top">
      <div class="logo">ARK PROJECT · 관리자</div>
      <div class="nav">
        <a href="/admin/new">개체 등록</a>
        <a href="/admin">보증서 발송</a>
        <a href="/admin/logs" class="active">발송 내역</a>
        <form method="POST" action="/admin/logout" style="display:inline"><button class="logout" type="submit">로그아웃</button></form>
      </div>
    </div>

    <% if (error) { %><div class="alert err">⚠️ <%= error %></div><% } %>
    <% if (notice) { %><div class="alert ok">✅ <%= notice %></div><% } %>

    <div class="panel">
      <div class="ph">발송 내역 (<%= logs.length %>건) · 최신순</div>
      <% if (logs.length === 0) { %>
        <div class="empty">아직 발송 내역이 없습니다. 보증서를 발송하면 여기에 자동으로 기록됩니다.</div>
      <% } else { %>
        <table>
          <tr><th>일시</th><th>고유번호</th><th>품종명</th><th>전화번호</th><th>채널</th><th>상태</th><th></th></tr>
          <% logs.forEach(function (log) { %>
          <tr>
            <td class="muted"><%= log['일시'] || '' %></td>
            <td><%= log['고유번호'] || '' %></td>
            <td><%= log['품종명'] || '' %></td>
            <td><%= log['전화번호'] || '' %></td>
            <td><%= log['채널'] || '' %></td>
            <td><%= log['상태'] || '' %></td>
            <td>
              <form method="POST" action="/admin/logs/delete" onsubmit="return confirm('이 내역을 삭제할까요?');" style="margin:0">
                <input type="hidden" name="rowNumber" value="<%= log._rowNumber %>" />
                <button class="del" type="submit">삭제</button>
              </form>
            </td>
          </tr>
          <% }); %>
        </table>
      <% } %>
    </div>

    <div class="panel">
      <div class="ph">내역 수동 추가</div>
      <form method="POST" action="/admin/logs/add">
        <div class="addgrid">
          <input name="일시" placeholder="일시 (비우면 현재)" />
          <input name="고유번호" placeholder="고유번호" />
          <input name="품종명" placeholder="품종명" />
          <input name="전화번호" placeholder="전화번호" />
          <input name="채널" placeholder="채널 (예: 문자)" />
          <input name="상태" placeholder="상태 (예: 성공)" />
        </div>
        <div class="hint">과거 발송분이나 수기 기록을 직접 남길 때 사용하세요.</div>
        <div class="addbar"><button type="submit">추가하기</button></div>
      </form>
    </div>
  </div>
</body>
</html>
